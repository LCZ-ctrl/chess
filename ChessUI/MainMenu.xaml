<Window x:Class="ChessUI.MainMenu"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Chess"
        Width="600"
        SizeToContent="Height"
        WindowStartupLocation="CenterScreen"
        Icon="Assets/icon.ico"
        Background="#101010"
        ResizeMode="CanMinimize"
        ShowInTaskbar="True">
    <Viewbox>
        <Grid x:Name="MenuGrid" Width="600" Height="600">
            <Grid.Background>
                <ImageBrush ImageSource="Assets/Menu1.png"
                            Stretch="UniformToFill"/>
            </Grid.Background>
            <!-- Main Menu -->
            <StackPanel x:Name="MainMenuPanel"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Center"
                        Visibility="Visible">
                <TextBlock x:Name="TitleText"
                           Text="CHESS"
                           Foreground="White"
                           FontSize="36"
                           FontWeight="Bold"
                           FontFamily="Segoe UI"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,20"/>
                <Button x:Name="PlayButton"
                        Width="200" Height="50"
                        Content="PLAY(2P)"
                        Click="PlayButton_Click"
                        Style="{StaticResource ButtonStyle}"
                        Margin="0,0,0,5"/>
                <Button x:Name="ComputerButton"
                        Width="200" Height="50"
                        Content="VS COMPUTER"
                        Click="ComputerButton_Click"
                        Style="{StaticResource ButtonStyle}"
                        Margin="0,0,0,5"/>
                <Button x:Name="InstructionButton"
                        Width="200" Height="50"
                        Content="INSTRUCTION"
                        Click="InstructionButton_Click"
                        Style="{StaticResource ButtonStyle}"
                        Margin="0,0,0,5"/>
                <Button x:Name="LanguageButton"
                        Width="200" Height="50"
                        Content="LANGUAGE"
                        Click="LanguageButton_Click"
                        Style="{StaticResource ButtonStyle}"
                        Margin="0,0,0,5"/>
                <Button x:Name="ExitButton"
                        Width="200" Height="50"
                        Content="EXIT"
                        Click="ExitButton_Click"
                        Style="{StaticResource ButtonStyle}"/>
            </StackPanel>
            <!-- Instruction Box -->
            <Border x:Name="InstructionBox"
                    Width="400"
                    Height="400"
                    Background="#CC101010"
                    BorderBrush="White"
                    BorderThickness="2"
                    CornerRadius="10"
                    Visibility="Collapsed"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Padding="10">
                <Grid>
                    <Button x:Name="CloseInstructionButton"
                            Content="✕"
                            Width="30"
                            Height="30"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Top"
                            Background="Transparent"
                            Foreground="White"
                            BorderBrush="Transparent"
                            FontSize="16"
                            Click="CloseInstructionButton_Click"/>
                    <ScrollViewer Margin="0,40,0,0">
                        <TextBlock x:Name="InstructionText"
                                   TextWrapping="Wrap"
                                   Foreground="White"
                                   FontSize="16"/>
                    </ScrollViewer>
                </Grid>
            </Border>
            <!-- Language Menu -->
            <Grid x:Name="LanguageMenuPanel"
                  VerticalAlignment="Center"
                  HorizontalAlignment="Center"
                  Visibility="Collapsed">
                <StackPanel>
                    <TextBlock x:Name="LanguageTitleText"
                               Text="LANGUAGE"
                               Foreground="White"
                               FontSize="36"
                               FontWeight="Bold"
                               FontFamily="Segoe UI"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,20"/>
                    <Button Content="English"
                            Width="200" Height="50"
                            Style="{StaticResource ButtonStyle}"
                            Margin="0,0,0,5"
                            Click="EnglishButton_Click"/>
                    <Button Content="中文"
                            Width="200" Height="50"
                            Style="{StaticResource ButtonStyle}"
                            Margin="0,0,0,5"
                            Click="ChineseButton_Click"/>
                    <Button Content="Русский"
                            Width="200" Height="50"
                            Style="{StaticResource ButtonStyle}"
                            Margin="0,0,0,20"
                            Click="RussianButton_Click"/>
                    <Button x:Name="BackFromLanguageButton"
                            Content="← BACK"
                            Width="150" Height="40"
                            Style="{StaticResource ButtonStyle}"
                            Click="BackFromLanguageButton_Click"/>
                </StackPanel>
            </Grid>
            <!-- Computer Menu -->
            <Grid x:Name="ComputerMenuPanel"
                  VerticalAlignment="Center"
                  HorizontalAlignment="Center"
                  Visibility="Collapsed">
                <StackPanel>
                    <TextBlock x:Name="ComputerTitleText"
                               Text="VS COMPUTER"
                               Foreground="White"
                               FontSize="36"
                               FontWeight="Bold"
                               FontFamily="Segoe UI"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,20"/>
                    <TextBlock x:Name="SideText"
                               Text="CHOOSE SIDE"
                               Foreground="White"
                               FontSize="20"
                               FontWeight="Bold"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,10"/>
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Center"
                                Margin="0,0,0,20">
                        <Button x:Name="WhiteButton"
                                Width="100" Height="50"
                                Style="{StaticResource ButtonStyle}"
                                Margin="0,0,15,0"
                                Click="WhiteButton_Click"/>
                        <Button x:Name="BlackButton"
                                Width="100" Height="50"
                                Style="{StaticResource ButtonStyle}"
                                Click="BlackButton_Click"/>
                    </StackPanel>
                    <TextBlock x:Name="DifficultyText"
                               Text="CHOOSE DIFFICULTY"
                               Foreground="White"
                               FontSize="20"
                               FontWeight="Bold"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,10"/>
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Center"
                                Margin="0,0,0,20">
                        <Button x:Name="BeginnerButton"
                                Width="80" Height="50"
                                Style="{StaticResource ButtonStyle}"
                                Margin="0,0,10,0"
                                Click="BeginnerButton_Click"/>
                        <Button x:Name="EasyButton"
                                Width="80" Height="50"
                                Style="{StaticResource ButtonStyle}"
                                Margin="0,0,10,0"
                                Click="EasyButton_Click"/>
                        <Button x:Name="MediumButton"
                                Width="80" Height="50"
                                Style="{StaticResource ButtonStyle}"
                                Margin="0,0,10,0"
                                Click="MediumButton_Click"/>
                        <Button x:Name="HardButton"
                                Width="80" Height="50"
                                Style="{StaticResource ButtonStyle}"
                                Margin="0,0,10,0"
                                Click="HardButton_Click"/>
                        <Button x:Name="MasterButton"
                                Width="80" Height="50"
                                Style="{StaticResource ButtonStyle}"
                                Click="MasterButton_Click"/>
                    </StackPanel>
                    <Button x:Name="StartComputerButton"
                            Width="200" Height="50"
                            Content="START GAME"
                            Click="StartComputerButton_Click"
                            Style="{StaticResource ButtonStyle}"
                            Margin="0,0,0,20"
                            IsEnabled="False"/>
                    <Button x:Name="BackFromComputerButton"
                            Content="← BACK"
                            Width="150" Height="40"
                            Style="{StaticResource ButtonStyle}"
                            Click="BackFromComputerButton_Click"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Viewbox>
</Window>